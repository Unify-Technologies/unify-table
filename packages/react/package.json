{
  "name": "@unify/table-react",
  "sideEffects": false,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/panel.css",
    "./themes": "./dist/themes.css",
    "./displays": "./dist/displays/display.css",
    "./table": "./dist/table.css"
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.json && cp src/panels/panel.css dist/panel.css && cp src/styles/themes.css dist/themes.css && cp src/styles/table.css dist/table.css && mkdir -p dist/displays && cp src/displays/display.css dist/displays/display.css",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-virtual": "^3.13.6",
    "@unify/table-charts": "workspace:*",
    "@unify/table-core": "workspace:*",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
